{
  "name": "prodeazo-predictions-api",
  "version": "0.1.0",
  "description": "API serverless de predicciones de Prodeazo — AWS CDK + Lambda + DynamoDB + Cognito + SNS",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",

    "floci:up": "docker compose -f docker-compose.floci.yml up -d",
    "floci:down": "docker compose -f docker-compose.floci.yml down",
    "floci:logs": "docker compose -f docker-compose.floci.yml logs -f",

    "bootstrap:local": "cdklocal bootstrap aws://000000000000/us-east-1",
    "deploy:local": "cdklocal deploy --require-approval never",
    "destroy:local": "cdklocal destroy --force",
    "synth": "cdk synth"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/client-sns": "^3.620.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.150.0",
    "aws-cdk-lib": "^2.150.0",
    "aws-cdk-local": "^2.21.0",
    "constructs": "^10.3.0",
    "typescript": "~5.5.0",
    "@types/node": "^20.14.0",
    "@types/aws-lambda": "^8.10.143",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "source-map-support": "^0.5.21"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/lambda"],
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": ["lambda/**/*.ts", "!lambda/**/*.test.ts"]
  }
}
